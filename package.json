{
  "name": "quant-farm",
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "arena": "ts-node src/arena.ts",
    "arena:dry": "DRY_RUN=true ts-node src/arena.ts",
    "arena:live": "ts-node src/arena.ts",
    "arena:1round": "MAX_ROUNDS=1 ts-node src/arena.ts",
    "arena:1round:dry": "DRY_RUN=true MAX_ROUNDS=1 ROUND_DURATION_MS=60000 TICK_INTERVAL_MS=200 ts-node src/arena.ts",
    "discover": "ts-node src/discovery.ts",
    "signals": "ts-node src/signals.ts",
    "pulse:test": "ts-node src/pulse.ts",
    "test:unit": "ts-node src/tests/unitTests.ts",
    "breed": "ts-node src/breeder.ts",
    "breed:analyze": "ts-node src/breeder.ts --analyze",
    "breed:loop": "ts-node src/breeder.ts --loop",
    "deploy": "bash scripts/deploy.sh",
    "logs": "ssh ${VPS_HOST:-root@165.22.29.245} 'pm2 logs quant-arena --lines 50'"
  },
  "dependencies": {
    "@ethersproject/abi": "^5.8.0",
    "@ethersproject/constants": "^5.8.0",
    "@ethersproject/contracts": "^5.8.0",
    "@ethersproject/providers": "^5.8.0",
    "@ethersproject/units": "^5.8.0",
    "@ethersproject/wallet": "^5.8.0",
    "@polymarket/clob-client-v2": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.4.1",
    "node-telegram-bot-api": "^0.67.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
