# Quant Farm — environment variables
# Copy to `.env` and fill in. .env is gitignored.

# ── Required for live trading ───────────────────────────────────────────────
# Private key of the Polygon wallet that funds + signs PM trades. Used by
# clob-client-v2 to authenticate orders and by merger.ts for the on-chain
# burn-pair primitive. NEVER commit this — `.env` is in `.gitignore`.
PRIVATE_KEY=

# Public address of the funder wallet (derived from PRIVATE_KEY). Required
# for live-arena reconciliation, Activity API queries, and live PnL ledger.
FUNDER=

# ── Required for live trading: Polymarket CLOB credentials ──────────────────
# Generate via the Polymarket UI under "API keys" or via the v2 SDK's
# createOrDeriveApiKey. These authorize order placement.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Optional: signature type override. Default is the proxy/funder pattern
# (signatureType=2). See clobClient.ts for details.
# SIGNATURE_TYPE=2

# ── VPS deploy target (scripts/deploy.sh + scripts/deploy-engines.sh) ───────
# SSH-style endpoint. Default placeholder — override before deploying.
QUANT_VPS_HOST=root@vps.example.com

# ── External API keys (breeder + signals) ───────────────────────────────────
# Anthropic — used by breeder.ts for engine code generation
# (Default CODER_MODEL is anthropic/claude-haiku-4-5)
ANTHROPIC_API_KEY=

# OpenRouter — alternative model provider for breeder, also used as a
# unified endpoint for non-Anthropic models
OPENROUTER_API_KEY=

# Telegram bot — for phone monitoring of live arena status (optional)
TELEGRAM_BOT_TOKEN=
# TELEGRAM_MODEL=anthropic/claude-haiku-4-5

# ── Polygon RPC (optional, for merger.ts on-chain calls) ────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_RPC_FALLBACK=https://polygon-rpc.com

# ── Arena tuning (per-process; defaults are fine for most cases) ────────────
# ARENA_COIN=btc                   # which coin this PM2 instance trades
# ARENA_INSTANCE_ID=btc-1h         # arena slot id (e.g. btc, btc-15m, btc-1h, btc-4h)
# BREED_INTERVAL_HOURS=6
# MIN_NEW_ROUNDS_TO_BREED=3
# CODER_MODEL=anthropic/claude-haiku-4-5
# ANALYST_MODEL=google/gemini-flash-1.5

# ── File paths (optional overrides) ─────────────────────────────────────────
# QUANT_DATA_DIR=data              # ledger + state files
# QUANT_CONFIG_DIR=config          # versioned config (sim_unreliable.json)

# ── Live trading safety nets (optional overrides) ───────────────────────────
# MAX_LIVE_TRADE_USD=8                 # flat per-order ceiling (May 6)
# TRIAL_BANKROLL_USD=5                 # new-engine trial size (May 6)
# TRIAL_FIRE_COUNT=5                   # settled fires before graduation (May 6)
# STREAK_CULL_N=5                      # consecutive sim losses → auto-cull
# PORTFOLIO_HALT_LOSS_USD=15           # combined realized + open MTM threshold
# PORTFOLIO_HALT_LOOKBACK_HOURS=6      # rolling window for portfolio halt
# PORTFOLIO_HALT_INCLUDE_MTM=true      # include open-position MTM in halt math
