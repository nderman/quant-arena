# Quant Farm — environment variables
# Copy to `.env` and fill in. .env is gitignored.

# ── Polygon wallet (required for live trading) ──────────────────────────────
# Private key of the wallet that funds and signs PM trades. Used by
# clob-client-v2 to authenticate orders and by merger.ts for the on-chain
# burn-pair primitive. NEVER commit this — `.env` is in `.gitignore`.
PRIVATE_KEY=

# ── Polymarket addresses ────────────────────────────────────────────────────
# The funder wallet's address (derived from PRIVATE_KEY). Required for the
# live-arena reconciliation and Activity API queries.
FUNDER=

# ── VPS deploy target (for scripts/deploy.sh + scripts/deploy-engines.sh) ───
# SSH-style endpoint. Default placeholder — override before deploying.
QUANT_VPS_HOST=root@vps.example.com

# ── External API keys ───────────────────────────────────────────────────────
# Anthropic — used by breeder.ts for code generation
ANTHROPIC_API_KEY=

# OpenRouter — alternative model provider for breeder
OPENROUTER_API_KEY=

# Google Gemini — used by breeder for round-summary analysis
GOOGLE_API_KEY=

# ── Polygon RPC (optional) ──────────────────────────────────────────────────
# Default to the public endpoint; override for higher rate limits.
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_RPC_FALLBACK=https://polygon-rpc.com

# ── Arena tuning (per-process; defaults are fine for most cases) ────────────
# ARENA_COIN=btc                   # which coin this PM2 instance trades
# ARENA_INSTANCE_ID=btc-1h         # arena slot id (e.g. btc, btc-15m, btc-1h, btc-4h)
# BREED_INTERVAL_HOURS=6
# MIN_NEW_ROUNDS_TO_BREED=3
# CODER_MODEL=anthropic/claude-haiku-4-5

# ── Live trading safety nets (optional overrides) ───────────────────────────
# MAX_LIVE_TRADE_USD=8                 # flat per-order ceiling
# TRIAL_BANKROLL_USD=5                 # new-engine trial size
# TRIAL_FIRE_COUNT=5                   # settled fires before graduation
# STREAK_CULL_N=5                      # consecutive sim losses before auto-cull
# PORTFOLIO_HALT_LOSS_USD=25
# PORTFOLIO_HALT_LOOKBACK_HOURS=12
